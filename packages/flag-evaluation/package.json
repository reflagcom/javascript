{
  "name": "@reflag/flag-evaluation",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reflagcom/javascript.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest",
    "test:ci": "vitest --reporter=default --reporter=junit --outputFile=junit.xml",
    "lint": "oxlint .",
    "lint:ci": "oxlint .",
    "format": "yarn fmt:fix && yarn lint:fix",
    "preversion": "yarn lint && yarn fmt && yarn vitest run -c vite.config.js && yarn build",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --check .",
    "fmt:fix": "oxfmt --write ."
  },
  "dependencies": {
    "js-sha256": "0.11.0"
  },
  "devDependencies": {
    "@reflag/tsconfig": "^0.0.2",
    "@types/node": "^22.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^2.0.5"
  }
}
