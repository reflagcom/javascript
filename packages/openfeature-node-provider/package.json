{
  "name": "@reflag/openfeature-node-provider",
  "version": "1.0.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reflagcom/javascript.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest -c vite.config.js",
    "test:ci": "vitest run -c vite.config.js --reporter=default --reporter=junit --outputFile=junit.xml",
    "coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:ci": "oxlint .",
    "format": "yarn fmt:fix && yarn lint:fix",
    "preversion": "yarn lint && yarn fmt && yarn vitest run -c vite.config.js && yarn build",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --check .",
    "fmt:fix": "oxfmt --write ."
  },
  "dependencies": {
    "@reflag/node-sdk": "1.4.2"
  },
  "devDependencies": {
    "@babel/core": "~7.24.7",
    "@openfeature/core": "^1.5.0",
    "@openfeature/server-sdk": ">=1.16.1",
    "@reflag/tsconfig": "~0.0.2",
    "@types/node": "^22.12.0",
    "flush-promises": "~1.0.2",
    "ts-node": "~10.9.2",
    "typescript": "^5.7.3",
    "vite": "~5.4.18",
    "vite-plugin-dts": "~3.9.1",
    "vitest": "~1.6.0"
  },
  "peerDependencies": {
    "@openfeature/server-sdk": ">=1.16.1"
  }
}
