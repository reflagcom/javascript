{
  "name": "@reflag/cli",
  "version": "1.0.4",
  "description": "CLI for Reflag service",
  "homepage": "https://docs.reflag.com/",
  "license": "MIT",
  "author": "Reflag.",
  "repository": {
    "type": "git",
    "url": "https://github.com/reflagcom/javascript.git"
  },
  "bin": {
    "reflag": "./dist/index.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "reflag": "yarn build && ./dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "yarn test --reporter=default --reporter=junit --outputFile=junit.xml",
    "coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:ci": "oxlint .",
    "format": "yarn fmt:fix && yarn lint:fix",
    "preversion": "yarn lint && yarn fmt && yarn vitest run -c vite.config.js && yarn build",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --check .",
    "fmt:fix": "oxfmt --write ."
  },
  "dependencies": {
    "@inquirer/prompts": "^7.9.0",
    "ajv": "^8.17.1",
    "chalk": "^5.3.0",
    "change-case": "^5.4.4",
    "commander": "^12.1.0",
    "comment-json": "^4.2.5",
    "express": "^4.21.2",
    "fast-deep-equal": "^3.1.3",
    "find-up": "^7.0.0",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "semver": "^7.7.2",
    "slug": "^10.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@reflag/tsconfig": "^0.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.5.1",
    "@types/semver": "^7.7.0",
    "@types/slug": "^5.0.9",
    "shx": "^0.3.4",
    "typescript": "^5.5.4",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@4.1.1"
}
